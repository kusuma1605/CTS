{
  // Place this file in your Angular project's .vscode/ folder.
  // Requires the "Debugger for Chrome" (built-in to modern VS Code as
  // "JavaScript Debugger") and the app running via `ng serve`.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "ng serve and debug",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:/*": "${webRoot}/*",
        "/./*": "${webRoot}/*",
        "/src/*": "${webRoot}/*",
        "/*": "*"
      }
    },
    {
      "type": "chrome",
      "request": "attach",
      "name": "Attach to running Chrome",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ]
}
